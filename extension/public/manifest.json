{
  "manifest_version": 3,
  "name": "PrepSnippet",
  "description": "Analyze selected code on any page using PrepSnippet AI.",
  "version": "1.0.0",
  "action": {
    "default_title": "PrepSnippet Analyze",
    "default_popup": "index.html"
  },
  "permissions": ["activeTab", "tabs", "storage"],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:5000/*",
    "https://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
